# Absolute URL of the Task Builder backend API.
#
# Leave EMPTY for local dev — requests then go to relative /api/* and the Vite
# dev server proxies them to the backend (see vite.config.js), so there is no
# CORS in dev. In a production build this value is baked in at build time, so
# set it to the deployed backend, e.g. https://taskbuilder-dev.utkrusht.ai
VITE_API_BASE=

# Dev-only: where `vite dev` proxies /api to when VITE_API_BASE is empty.
VITE_DEV_PROXY_TARGET=http://127.0.0.1:8000
