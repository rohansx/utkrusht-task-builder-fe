# Absolute URL of the Task Builder backend API.
#
# Leave EMPTY for local dev — requests then go to relative /api/* and the Vite
# dev server proxies them to the backend (see vite.config.js), so there is no
# CORS in dev. In a production build this value is baked in at build time, so
# set it to the deployed backend, e.g. https://taskbuilder-dev.utkrusht.ai
VITE_API_BASE=

# Dev-only: where `vite dev` proxies /v2/* to (the local Flask backend).
VITE_DEV_PROXY_TARGET=http://127.0.0.1:4000

# Optional: a dev testmaker JWT. When set, the UI auto-attaches it as
# `Authorization: Bearer <jwt>` (+ `X-Token-Source: recruiter`) and NEVER
# prompts. Leave EMPTY to keep the prompt-once flow.
#
# ⚠️  SECURITY: Vite bakes this into the client bundle at build time, so it is
# readable by anyone who loads the app (View Source / DevTools). Only use it
# for LOCAL/STAGING dev.
VITE_DEV_JWT=

# Skills panel data source — the dev Supabase `competencies` table, read directly
# via its REST endpoint (the table has a public SELECT policy, so the anon key is
# enough and no backend endpoint is involved). Leave empty to hide the skills list
# (the roles/stacks suggestions still show). anon keys are public-safe by design.
VITE_SUPABASE_URL=https://<dev-ref>.supabase.co
VITE_SUPABASE_ANON_KEY=<dev anon key>

# Optional: PostHog analytics (see README).
# VITE_POSTHOG_KEY=
# VITE_POSTHOG_HOST=https://us.i.posthog.com
